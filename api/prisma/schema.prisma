generator client {
  provider = "prisma-client-js"
  // Ship binaries for both glibc (Railway/Nixpacks) and musl (Dockerfile) runtimes
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  logoDataUrl String?
  accentColor String?
  accentColor2 String?
  crmMode   String   @default("B2B")
  crmDisplayCurrency String @default("USD")
  industry  String?
  contractSetup Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  clients Client[]
  tasks   Task[]
  invoices Invoice[]
  subscriptions Subscription[]
  pipelines Pipeline[]
  stages Stage[]
  deals Deal[]
  dealStageHistory DealStageHistory[]
  products Product[]
  dealItems DealItem[]
  userInvites UserInvite[]
  salonBranches SalonBranch[]
  salonCollaborators SalonCollaborator[]
  salonSuppliers SalonSupplier[]
  salonServiceCategories SalonServiceCategory[]
  salonServices SalonService[]
  salonProducts SalonProduct[]
  salonInventoryMovements SalonInventoryMovement[]
  salonServiceEntries SalonServiceEntry[]
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(MEMBER)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  deals  Deal[] @relation("DealOwner")
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId          String
  customerTenantId  String             @unique
  customerName      String
  contactFirstName  String?
  contactLastName   String?
  contactEmail      String?
  plan              String             @default("TRIAL")
  seats             Int                @default(1)
  trialEndsAt       DateTime?
  status            SubscriptionStatus @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model UserInvite {
  id              String       @id @default(uuid())
  tenantId        String
  email           String
  name            String?
  role            UserRole     @default(MEMBER)
  token           String       @unique
  status          InviteStatus @default(PENDING)
  invitedByUserId String?
  acceptedByUserId String?
  acceptedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, email])
}

model Client {
  id        String   @id @default(uuid())
  firstName String?
  name      String
  function  String?
  companySector String?
  email     String?
  phone     String?
  company   String?
  website   String?
  address   String?
  taxId     String?
  notes     String?
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  tasks   Task[]
  invoices Invoice[]
  deals   Deal[]
  salonServiceEntries SalonServiceEntry[]
}

model Task {
  id        String     @id @default(uuid())
  title     String
  status    TaskStatus @default(PENDING)
  dueDate   DateTime?
  timeSpentHours Decimal? @db.Decimal(8, 2)
  amount    Decimal?   @db.Decimal(12, 2)
  currency  String     @default("USD")
  tenantId  String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
}

model Invoice {
  id           String         @id @default(uuid())
  tenantId     String
  clientId     String?
  amount       Decimal        @db.Decimal(10, 2)
  currency     String         @default("USD")
  status       InvoiceStatus  @default(NEW)
  filePath     String
  issuedDate   DateTime?
  dueDate      DateTime?
  extractedRaw Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  isDefault Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  stages Stage[]
  deals  Deal[]
}

model Stage {
  id         String      @id @default(uuid())
  name       String
  position   Int
  probability Float      @default(0)
  status     StageStatus @default(OPEN)
  tenantId   String
  pipelineId String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  pipeline Pipeline @relation(fields: [pipelineId], references: [id])
  deals    Deal[]
  historyFrom DealStageHistory[] @relation("FromStage")
  historyTo   DealStageHistory[] @relation("ToStage")
}

model Deal {
  id               String   @id @default(uuid())
  title            String
  value            Decimal  @db.Decimal(12, 2)
  currency         String   @default("USD")
  expectedCloseDate DateTime?
  proposalFilePath String?
  clientId         String?
  ownerId          String?
  tenantId         String
  pipelineId       String
  stageId          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner    User?    @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipeline Pipeline @relation(fields: [pipelineId], references: [id])
  stage    Stage    @relation(fields: [stageId], references: [id])
  history  DealStageHistory[]
  items    DealItem[]

  @@index([ownerId])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal? @db.Decimal(12, 2)
  currency    String   @default("USD")
  isActive    Boolean  @default(true)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  dealItems DealItem[]

  @@index([tenantId])
}

model DealItem {
  id        String   @id @default(uuid())
  tenantId  String
  dealId    String
  productId String
  quantity  Int      @default(1)
  unitPrice Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([dealId, productId])
  @@index([tenantId])
  @@index([dealId])
  @@index([productId])
}

enum SalonInventoryMovementType {
  PURCHASE
  ADJUSTMENT
  CONSUMPTION
  TRANSFER_IN
  TRANSFER_OUT
}

model SalonBranch {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  licenseCode String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  collaborators SalonCollaborator[]
  products      SalonProduct[]
  serviceEntries SalonServiceEntry[]
  inventoryMovements SalonInventoryMovement[]

  @@index([tenantId])
  @@unique([tenantId, name])
}

model SalonCollaborator {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String
  code      Int?
  name      String
  roleLabel String?
  email     String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         SalonBranch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  serviceEntries SalonServiceEntry[]

  @@index([tenantId])
  @@index([branchId])
  @@unique([tenantId, branchId, name])
}

model SalonSupplier {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  executive String?
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products SalonProduct[]

  @@index([tenantId])
  @@unique([tenantId, name])
}

model SalonServiceCategory {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  position  Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services SalonService[]

  @@index([tenantId])
  @@unique([tenantId, name])
  @@unique([tenantId, position])
}

model SalonService {
  id          String   @id @default(uuid())
  tenantId    String
  categoryId  String?
  key         String?
  name        String
  price1      Decimal? @db.Decimal(12, 2)
  price2      Decimal? @db.Decimal(12, 2)
  price3      Decimal? @db.Decimal(12, 2)
  collaboratorPrice Decimal? @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       SalonServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  serviceEntries SalonServiceEntry[]

  @@index([tenantId])
  @@index([categoryId])
  @@unique([tenantId, name])
}

model SalonProduct {
  id          String   @id @default(uuid())
  tenantId    String
  branchId    String?
  supplierId  String?
  code        String?
  name        String
  line        String?
  brand       String?
  price1      Decimal? @db.Decimal(12, 2)
  price2      Decimal? @db.Decimal(12, 2)
  price3      Decimal? @db.Decimal(12, 2)
  collaboratorPrice Decimal? @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  stock       Decimal? @db.Decimal(12, 3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    SalonBranch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  supplier  SalonSupplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  inventoryMovements SalonInventoryMovement[]

  @@index([tenantId])
  @@index([branchId])
  @@index([supplierId])
  @@unique([tenantId, name])
}

model SalonInventoryMovement {
  id          String                     @id @default(uuid())
  tenantId    String
  branchId    String?
  productId   String
  type        SalonInventoryMovementType
  quantity    Decimal                    @db.Decimal(12, 3)
  reason      String?
  createdById String?
  createdAt   DateTime                   @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  SalonBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  product SalonProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([productId])
}

model SalonServiceEntry {
  id             String   @id @default(uuid())
  tenantId       String
  branchId       String
  collaboratorId String
  clientId       String?
  serviceId      String?
  serviceName    String
  clientName     String
  quantity       Decimal  @default(1) @db.Decimal(10, 2)
  amount         Decimal  @db.Decimal(12, 2)
  durationMinutes Int?
  happenedAt     DateTime
  notes          String?
  consumptions   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       SalonBranch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  collaborator SalonCollaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  client       Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  service      SalonService?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([tenantId, happenedAt])
  @@index([branchId, happenedAt])
  @@index([collaboratorId, happenedAt])
  @@index([clientId])
}

model DealStageHistory {
  id          String   @id @default(uuid())
  tenantId    String
  dealId      String
  fromStageId String?
  toStageId   String
  movedAt     DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  deal     Deal   @relation(fields: [dealId], references: [id])
  fromStage Stage? @relation("FromStage", fields: [fromStageId], references: [id])
  toStage   Stage  @relation("ToStage", fields: [toStageId], references: [id])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum InvoiceStatus {
  NEW
  PROCESSING
  READY
}

enum StageStatus {
  OPEN
  WON
  LOST
}
